# DJANGO
# SECRET_KEY Can be generated here: https://djecrety.ir/
SECRET_KEY=
DJANGO_DEBUG=False
ALLOWED_HOSTS="backend.net,frontend.com"
CSRF_TRUSTED_ORIGINS="https://backend.net,https://frontend.com"
CORS_ALLOWED_ORIGINS="https://backend.net,https://frontend.com"
CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.frontend\.net$'
PAGINATION=100

# DATABASE
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
# Your database host (db is the database service name in compose.yml)
POSTGRES_HOST=db
POSTGRES_PORT=
